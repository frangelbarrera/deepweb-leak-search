# Database connection string
DATABASE_URL="postgres://user:password@host:5432/dbname"

# Tor SOCKS5 proxy (optional — omit to fetch directly)
UPSTREAM_PROXY="socks5://127.0.0.1:9050"

# Tor ControlPort for identity rotation
TOR_CONTROL_HOST="127.0.0.1"
TOR_CONTROL_PORT="9051"

# Optional: Tor ControlPort password (leave empty if CookieAuthentication is disabled)
TOR_CONTROL_PASSWORD=""
